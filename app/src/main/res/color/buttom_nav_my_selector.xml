<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:color="@color/black2" android:state_pressed="true" />

    <!-- 选中状态 -->
    <item android:color="@color/black2" android:state_selected="true" />

    <!-- 获取焦点状态 -->
    <item android:color="@color/black2" android:state_focused="true" />

    <!-- 不可用状态 -->
    <item android:color="@color/un_active" android:state_enabled="false" />

    <!-- 默认状态 -->
    <item android:color="@color/un_active" />
</selector>